local function RefreshList()
    -- Clear current list except Layout
    for _, item in pairs(P_Players:GetChildren()) do
        if item:IsA("Frame") then item:Destroy() end
    end
    
    -- Loop through all active players
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer then
            local f = Instance.new("Frame", P_Players)
            f.Size = UDim2.new(0.95, 0, 0, 55)
            f.BackgroundColor3 = Color3.fromRGB(25, 5, 5)
            Instance.new("UICorner", f)

            local img = Instance.new("ImageLabel", f)
            img.Size = UDim2.new(0, 45, 0, 45)
            img.Position = UDim2.new(0, 5, 0.5, -22.5)
            img.BackgroundColor3 = Color3.fromRGB(20,0,0)
            Instance.new("UICorner", img).CornerRadius = UDim.new(1,0)
            
            pcall(function() 
                img.Image = Players:GetUserThumbnailAsync(p.UserId, Enum.ThumbnailType.HeadShot, Enum.ThumbnailSize.Size48x48) 
            end)

            local nameL = Instance.new("TextLabel", f)
            nameL.Text = "@"..p.Name
            nameL.Size = UDim2.new(0.25, 0, 1, 0)
            nameL.Position = UDim2.new(0, 55, 0, 0)
            nameL.TextColor3 = Color3.new(1,1,1)
            nameL.BackgroundTransparency = 1
            nameL.Font = "GothamBold"
            nameL.TextSize = 8
            nameL.TextXAlignment = "Left"

            local function btn(txt, x, col, cb)
                local b = Instance.new("TextButton", f)
                b.Text = txt
                b.Size = UDim2.new(0, 38, 0, 25)
                b.Position = UDim2.new(x, 0, 0.5, -12.5)
                b.BackgroundColor3 = col
                b.TextColor3 = Color3.new(1,1,1)
                b.Font = "GothamBold"
                b.TextSize = 7
                Instance.new("UICorner", b)
                b.MouseButton1Click:Connect(cb)
                return b
            end

            btn("VIEW", 0.40, Color3.fromRGB(100, 0, 0), function() Camera.CameraSubject = p.Character.Humanoid end)
            btn("UV", 0.55, Color3.fromRGB(150, 0, 0), function() Camera.CameraSubject = LocalPlayer.Character.Humanoid end)
            btn("GOTO", 0.70, Color3.fromRGB(0, 80, 0), function() if p.Character and p.Character:FindFirstChild("HumanoidRootPart") then LocalPlayer.Character.HumanoidRootPart.CFrame = p.Character.HumanoidRootPart.CFrame end end)
            
            local lb = btn("LOOP", 0.85, Color3.fromRGB(200, 0, 0), nil)
            lb.MouseButton1Click:Connect(function()
                if LoopBringData[p.UserId] then 
                    LoopBringData[p.UserId] = nil
                    lb.BackgroundColor3 = Color3.fromRGB(200, 0, 0)
                else 
                    if p.Character and LocalPlayer.Character then 
                        LoopBringData[p.UserId] = {Player = p, TargetPos = LocalPlayer.Character.HumanoidRootPart.CFrame * CFrame.new(0, 0, -3)}
                        lb.BackgroundColor3 = Color3.fromRGB(0, 180, 0) 
                    end 
                end
            end)
        end
    end
    -- Auto-adjust CanvasSize
    P_Players.CanvasSize = UDim2.new(0, 0, 0, PlayerListLayout.AbsoluteContentSize.Y + 10)
end

