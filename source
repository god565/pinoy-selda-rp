-- ESP RENDERING
local function HandleESP(p)
    if p == LocalPlayer then return end
    RunService.RenderStepped:Connect(function()
        local char = p.Character
        if char and char:FindFirstChild("HumanoidRootPart") and char:FindFirstChild("Humanoid") then
            if VisualsEnabled then
                local hl = char:FindFirstChild("ArthurHL") or Instance.new("Highlight", char); hl.Name = "ArthurHL"; hl.FillColor = Color3.fromRGB(255, 0, 0)
                local bbu = char:FindFirstChild("ArthurESP") or Instance.new("BillboardGui", char); bbu.Name = "ArthurESP"; bbu.AlwaysOnTop = true; bbu.Size = UDim2.new(0, 100, 0, 50); bbu.Adornee = char:FindFirstChild("Head"); bbu.ExtentsOffset = Vector3.new(0, 3, 0)
                local txt = bbu:FindFirstChild("Info") or Instance.new("TextLabel", bbu); txt.Name = "Info"; txt.BackgroundTransparency = 1; txt.Size = UDim2.new(1, 0, 1, 0); txt.Font = "GothamBold"; txt.TextSize = 12; txt.TextColor3 = Color3.new(1, 1, 1); txt.Text = "@"..p.Name.."\nHP: "..math.floor(char.Humanoid.Health)
            else 
                if char:FindFirstChild("ArthurHL") then char.ArthurHL:Destroy() end 
                if char:FindFirstChild("ArthurESP") then char.ArthurESP:Destroy() end 
            end
        end
    end)
end

